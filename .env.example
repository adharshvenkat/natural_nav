# Copy this file to .env
# cp .env.example .env

# LLM provider: ollama (local, default), anthropic, or openai
LLM_PROVIDER=ollama

# Model name (must match the provider)
#   ollama:    qwen2.5:3b, llama3.2:3b
#   anthropic: claude-sonnet-4-6, claude-opus-4-7
#   openai:    gpt-4o, gpt-4-turbo
LLM_MODEL=qwen2.5:3b

# Ollama server URL (used only when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434

# API key — only needed for anthropic/openai, leave blank for ollama
LLM_API_KEY=
